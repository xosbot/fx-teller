# FX-Teller — Environment variables
# Copy to .env on the VPS and fill in real values.

# --- Server ---
NODE_ENV=production
PORT=3000

# --- Database ---
POSTGRES_PASSWORD=CHANGE_ME_32_CHAR_RANDOM
DATABASE_URL=postgres://fxteller:CHANGE_ME_32_CHAR_RANDOM@db:5432/fxteller

# --- Auth ---
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM

# --- 100ms.live ---
# Get from https://dashboard.100ms.live after creating an app + template.
HMS_APP_ACCESS_KEY=
HMS_APP_SECRET=
HMS_TEMPLATE_ID=
HMS_ROLE_LISTENER=listener
HMS_ROLE_HOST=host

# --- Razorpay ---
# Get from https://dashboard.razorpay.com → Settings → API Keys
RZP_KEY_ID=rzp_test_xxx
RZP_KEY_SECRET=
# Webhook secret: created when you register a webhook in the Razorpay dashboard.
RZP_WEBHOOK_SECRET=
# Plan ID created once in Razorpay dashboard (or via their API). Monthly ₹499.
RZP_PLAN_MONTHLY=plan_xxx

# --- Public URLs ---
# Used by the host console at build time.
NEXT_PUBLIC_API_URL=https://api.fxteller.app/api
DOMAIN=fxteller.app
ADMIN_EMAIL=ops@fxteller.app
