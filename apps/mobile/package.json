{
  "name": "@fx-teller/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "build:android": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile preview",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "clean": "rm -rf .expo .turbo dist"
  },
  "dependencies": {
    "@fx-teller/shared-types": "workspace:*",
    "@100mslive/react-native-hms": "^1.12.2",
    "expo": "~52.0.20",
    "expo-router": "~4.0.14",
    "expo-status-bar": "~2.0.0",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-haptics": "~14.0.0",
    "expo-notifications": "~0.29.11",
    "expo-dev-client": "~5.0.8",
    "expo-av": "~15.0.1",
    "expo-splash-screen": "~0.29.18",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-razorpay": "^3.0.0",
    "expo-modules-core": "~2.0.0",
    "@react-native-async-storage/async-storage": "1.23.1"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.7.2"
  }
}
